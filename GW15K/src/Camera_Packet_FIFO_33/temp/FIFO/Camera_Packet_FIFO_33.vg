module Camera_Packet_FIFO_33 (
  Data,
  Reset,
  WrClk,
  RdClk,
  WrEn,
  RdEn,
  Wnum,
  Rnum,
  Almost_Empty,
  Almost_Full,
  Q,
  Empty,
  Full
)
;
input [32:0] Data;
input Reset;
input WrClk;
input RdClk;
input WrEn;
input RdEn;
output [13:0] Wnum;
output [13:0] Rnum;
output Almost_Empty;
output Almost_Full;
output [32:0] Q;
output Empty;
output Full;
wire VCC;
wire GND;
  \~fifo.Camera_Packet_FIFO_33  fifo_inst (
    .Reset(Reset),
    .RdClk(RdClk),
    .WrClk(WrClk),
    .WrEn(WrEn),
    .RdEn(RdEn),
    .Data(Data[32:0]),
    .Empty(Empty),
    .Full(Full),
    .Almost_Empty(Almost_Empty),
    .Almost_Full(Almost_Full),
    .Wnum(Wnum[13:0]),
    .Rnum(Rnum[13:0]),
    .Q(Q[32:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
  GSR GSR (
    .GSRI(VCC) 
);
endmodule /* Camera_Packet_FIFO_33 */
